import docx
import re
import pandas as pd
from google.colab import drive

# 1. Mount Google Drive
drive.mount('/content/drive')

def extract_animal_data(file_path):
    doc = docx.Document(file_path)
    full_text = []
    for para in doc.paragraphs:
        full_text.append(para.text)
    
    text = "\n".join(full_text)
    
    # This dictionary will hold Animal ID as Key and list of Data values as Value
    results = {}
    
    # Step 1: Find all Animal IDs at the start of a line (3 digits usually)
    # We look for a line that starts with a number, followed by spaces/tabs
    lines = text.split('\n')
    
    current_animal = None
    
    for line in lines:
        line = line.strip()
        if not line: continue
        
        # Check if line starts with an ID (e.g., 600) followed by 'N', 'Mean', etc.
        # We look for a number at the very beginning of the string
        match_id = re.match(r'^(\d{3,4})\s+', line)
        
        if match_id:
            current_animal = match_id.group(1)
            results[current_animal] = []
            
        # Step 2: Extract the data values (e.g., 90.1) associated with that ID
        if current_animal:
            # Look for numbers followed by the animal ID in parentheses: e.g., 90.1 (600)
            data_points = re.findall(rf'(\d+\.\d+|\d+)\s*\({current_animal}\)', line)
            results[current_animal].extend(data_points)

    return results

# --- EXECUTION ---
file_path = '/content/drive/My Drive/your_folder/your_file.docx' # Update this!
data_map = extract_animal_data(file_path)

# Convert to a DataFrame
# We'll make the Animal ID the header and the data points the rows
df = pd.DataFrame(dict([(k, pd.Series(v)) for k, v in data_map.items()]))

# Save to Excel
output_path = '/content/drive/My Drive/your_folder/Extracted_Data.xlsx'
df.to_excel(output_path, index=False)

print(f"Success! Data saved to {output_path}")
